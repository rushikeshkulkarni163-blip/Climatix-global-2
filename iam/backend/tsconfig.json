{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@auth/*": ["src/auth/*"],
      "@users/*": ["src/users/*"],
      "@organizations/*": ["src/organizations/*"],
      "@rbac/*": ["src/rbac/*"],
      "@sessions/*": ["src/sessions/*"],
      "@audit/*": ["src/audit/*"],
      "@email/*": ["src/email/*"],
      "@mfa/*": ["src/mfa/*"],
      "@subscriptions/*": ["src/subscriptions/*"],
      "@admin/*": ["src/admin/*"],
      "@common/*": ["src/common/*"],
      "@config/*": ["src/config/*"]
    }
  }
}
