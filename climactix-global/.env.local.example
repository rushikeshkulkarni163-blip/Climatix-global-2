# ── Climactix Global — Next.js Frontend Environment ─────────
# Copy to .env.local

# IAM Service URL (NestJS)
NEXT_PUBLIC_IAM_URL=http://localhost:3100/api/v1

# Server-side IAM URL (for middleware/server components — avoid CORS)
IAM_URL=http://localhost:3100/api/v1

# Intelligence Engine URL (FastAPI)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Mapbox token
NEXT_PUBLIC_MAPBOX_TOKEN=

# Feature flags
NEXT_PUBLIC_ENABLE_SSO=true
NEXT_PUBLIC_ENABLE_MFA=true
NEXT_PUBLIC_ENABLE_ENTERPRISE_SSO=true
