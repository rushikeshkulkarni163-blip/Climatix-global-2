# ── Server ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────
# Get free cluster at https://mongodb.com/atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/climatix?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_min_64_chars
JWT_EXPIRES_IN=1h
JWT_REMEMBER_EXPIRES_IN=30d

# ── Email (Gmail SMTP) ────────────────────────────────────
# Enable "App Passwords" in Google Account → Security
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM="Climactix Global <your@gmail.com>"

# ── Frontend URL (for email links) ────────────────────────
# Local development:
FRONTEND_URL=http://localhost:5500
# Production (e.g. Vercel / Netlify):
# FRONTEND_URL=https://climactixglobal.com

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
