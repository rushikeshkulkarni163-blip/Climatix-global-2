{
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions",
    "runtime": "python312"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "scripts/**",
      "backend/**",
      "functions/**",
      "climactix-ai/**",
      "climactix-global/**",
      "intelligence_engine/**",
      "climate_api/**",
      "iam/**",
      "*.md",
      "*.py"
    ]
  },
  "emulators": {
    "firestore": { "port": 8181 },
    "storage":   { "port": 9199 },
    "functions": { "port": 5001 },
    "ui":        { "enabled": true, "port": 4001 }
  }
}
