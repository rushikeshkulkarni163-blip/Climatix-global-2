// ── Climactix Global · Firestore Security Rules ────────────────────────────
//
// Matches the storage model in community.js: every CX.* key (posts, profiles,
// follows, forum threads, scores, funding requests, etc.) is ONE document in
// the `community_data` collection, holding the whole array/object as a
// single `value` field.
//
// Deploy: Firebase Console → Firestore Database → Rules tab → paste this in
// → Publish. (Or `firebase deploy --only firestore:rules` with the CLI.)
//
// ── KNOWN LIMITATION — read before relying on this ─────────────────────────
// Because each document is a whole-array blob, these rules can only gate
// "is this request from a logged-in user" — they CANNOT enforce field-level
// authorization such as "you may only delete your own post" or "you may not
// edit someone else's climate score." Any authenticated user can currently
// overwrite the entire posts/profiles/scores document, including other
// people's data — the authorId checks in community.js (e.g. deletePost)
// only run in client-side JS today and are trivially bypassable by anyone
// calling Firestore directly with a valid auth token.
//
// This is an accepted trade-off of the current bridge design (see the
// comment at the top of community.js). If/when this needs real per-user
// write authorization, migrate CX.POSTS (and similar) from one big
// document to a subcollection with one document per post, e.g.:
//   /posts/{postId}  { authorId, content, ... }
// so rules can check `request.resource.data.authorId == request.auth.uid`
// on create/update/delete.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /community_data/{key} {
      // Must be signed in (via Firebase Auth) to read or write any
      // community data — matches requireAuth() gating every page.
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
