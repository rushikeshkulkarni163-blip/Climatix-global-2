# Copernicus Climate Data Store (CDS) API credentials
# =====================================================
# 1. Register free account at: https://cds.climate.copernicus.eu/
# 2. Copy your Personal Access Token from your profile page
# 3. Rename this file to  ~/.cdsapirc  (in your home directory)
#    OR set environment variables CDS_API_KEY and CDS_API_URL
#
# Without credentials, Climactix falls back to its built-in
# scientifically-derived synthetic climate datasets automatically.

url: https://cds.climate.copernicus.eu/api
key: YOUR_CDS_PERSONAL_ACCESS_TOKEN_HERE
